        "method": "GET",
        "path": "/sso/launch{:param}",
        "handler": "SsoController#launch"
      },
      {
        "name": "callback",
        "method": "GET",
        "path": "/sso/callback{:param}",
        "handler": "SsoController#callback"
      },
      {
        "name": "health",
        "method": "GET",
        "path": "/sso/health{:param}",
        "handler": "SsoController#health"
      }
    ],
    "optional_routes": [
      {
        "name": "error",
        "method": "GET",
        "path": "/sso/error{:param}",
        "handler": "SsoController#error"
      }
    ]
